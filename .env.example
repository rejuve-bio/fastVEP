# Directory containing fastVEP genome data.
# Created by running: sudo FASTVEP_BIN=target/release bash scripts/deploy-full.sh
DATA_DIR=/opt/fastvep/data

# Default genome loaded at startup (hg38). Override to use a different assembly.
# FASTVEP_GFF3=/opt/fastvep/data/hg38_ensembl_115/Homo_sapiens.GRCh38.115.gff3
# FASTVEP_FASTA=/opt/fastvep/data/hg38_ensembl_115/Homo_sapiens.GRCh38.dna.primary_assembly.fa
# FASTVEP_SA_DIR=/opt/fastvep/data/hg38_ensembl_115/sa

# Port the JSON API will be available on.
API_PORT=8000

# Allowed CORS origins (comma-separated). Use * to allow all origins.
CORS_ORIGINS=*
